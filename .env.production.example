# ============================================
# Production Environment Configuration
# ============================================
# Copy to .env.production and configure for your production environment

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# URLs (update with your production domains)
API_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ============================================
# Database (PostgreSQL REQUIRED in production)
# ============================================
DATABASE_URL=postgresql://user:password@host:5432/investment?sslmode=require
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=true

# ============================================
# Redis (RECOMMENDED for production sessions)
# ============================================
REDIS_URL=redis://:password@host:6379

# ============================================
# Authentication (REQUIRED)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_GENERATE_A_SECURE_64_CHAR_HEX_STRING
JWT_SECRET=CHANGE_ME_GENERATE_ANOTHER_SECURE_64_CHAR_HEX_STRING

# Google OAuth
GOOGLE_CLIENT_ID=your_production_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_production_client_secret

# Admin emails
ADMIN_EMAILS=admin@yourdomain.com

# ============================================
# Financial Data APIs
# ============================================
ALPHA_VANTAGE_KEY=your_production_key
FRED_API_KEY=your_production_key

# ============================================
# Alternative Data APIs
# ============================================
COMPANIES_HOUSE_API_KEY=your_production_key
OPENFIGI_API_KEY=your_production_key

# ============================================
# AI/LLM Configuration
# ============================================
ANTHROPIC_API_KEY=your_production_key
LLM_DAILY_BUDGET=50
LLM_MONTHLY_BUDGET=500

# ============================================
# Monitoring (REQUIRED)
# ============================================
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=info

# ============================================
# Rate Limiting (REQUIRED)
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS (update with your domains)
# ============================================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
