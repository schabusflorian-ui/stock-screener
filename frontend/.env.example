# Frontend Environment Variables
# Copy this file to .env.local for local development

# API URL (backend)
# For local development: http://localhost:3000
# For Railway: https://your-app.up.railway.app
REACT_APP_API_URL=

# Admin Access Code (optional)
# Allows bypassing OAuth login with a code on the login page
# For local development: Auto-enabled on localhost (no code needed)
# For production: Set a unique, secure code (e.g., generate with: openssl rand -hex 16)
REACT_APP_ADMIN_CODE=

# Note: In production (Railway), you'll set these in the Railway dashboard
# under Variables, not in this file.
