# Frontend Environment Variables
# Copy this file to .env.local for local development

# API URL (backend)
# For local development: http://localhost:3000
# For Railway: https://your-app.up.railway.app
REACT_APP_API_URL=

# Admin Access Code (optional)
# Allows bypassing OAuth login with a code on the login page
# For local development: Auto-enabled on localhost
# For production: Set a secure code
# Default: prism-admin-2024 (change this for production!)
REACT_APP_ADMIN_CODE=prism-admin-2024

# Note: In production (Railway), you'll set these in the Railway dashboard
# under Variables, not in this file.
