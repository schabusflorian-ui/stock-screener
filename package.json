{
  "name": "investment-project",
  "version": "1.0.0",
  "description": "A tool for analyzing stocks using value investing metrics.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node src/api/server.js",
    "dev": "nodemon src/api/server.js",
    "scheduler": "node src/jobs/masterScheduler.js",
    "scheduler:status": "node src/jobs/masterScheduler.js --status",
    "scheduler:list": "node src/jobs/masterScheduler.js --list",
    "scheduler:run-all": "node src/jobs/masterScheduler.js --run-all",
    "scheduler:install": "cp com.investment-project.scheduler.plist ~/Library/LaunchAgents/ && launchctl load ~/Library/LaunchAgents/com.investment-project.scheduler.plist",
    "scheduler:uninstall": "launchctl unload ~/Library/LaunchAgents/com.investment-project.scheduler.plist && rm ~/Library/LaunchAgents/com.investment-project.scheduler.plist",
    "price-update": "node src/jobs/priceUpdateScheduler.js --now",
    "price-update:status": "node src/jobs/priceUpdateScheduler.js --status",
    "price-update:scheduler": "node src/jobs/priceUpdateScheduler.js",
    "price-update:dry-run": "node src/jobs/priceUpdateScheduler.js --dry-run",
    "knowledge:refresh": "node src/jobs/knowledgeBaseRefresh.js",
    "knowledge:refresh-full": "node src/jobs/knowledgeBaseRefresh.js --full",
    "knowledge:status": "node src/jobs/knowledgeBaseRefresh.js --status"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.5.0",
    "better-sqlite3-session-store": "^0.1.0",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "rss-parser": "^3.13.0",
    "uuid": "^13.0.0",
    "xml2js": "^0.6.2",
    "yahoo-finance2": "^3.10.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
