{
  "name": "investment-project",
  "version": "1.0.0",
  "description": "A tool for analyzing stocks using value investing metrics.",
  "main": "src/api/server.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node src/api/server.js",
    "start:production": "node scripts/start-production.js",
    "dev": "nodemon src/api/server.js",
    "build": "cd frontend && npm ci && npm run build",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:agent": "jest --config jest.config.js --testPathPattern=agent",
    "test:unified": "node tests/unified-strategy/runAllTests.js",
    "test:unified:verbose": "node tests/unified-strategy/runAllTests.js --verbose",
    "test:unified:signals": "node tests/unified-strategy/runAllTests.js --filter signals",
    "test:unified:backtest": "node tests/unified-strategy/runAllTests.js --filter backtest",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "db:migrate": "node src/lib/migrationRunner.js run",
    "db:migrate:status": "node src/lib/migrationRunner.js status",
    "db:migrate:postgres": "node src/database-migrations/run-postgres-migrations.js",
    "db:migrate:postgres:base": "node src/database-migrations/000-postgres-base-schema.js",
    "db:backup": "./scripts/backup-db.sh",
    "scheduler": "node src/jobs/masterScheduler.js",
    "scheduler:status": "node src/jobs/masterScheduler.js --status",
    "scheduler:list": "node src/jobs/masterScheduler.js --list",
    "scheduler:run-all": "node src/jobs/masterScheduler.js --run-all",
    "scheduler:install": "cp com.investment-project.scheduler.plist ~/Library/LaunchAgents/ && launchctl load ~/Library/LaunchAgents/com.investment-project.scheduler.plist",
    "scheduler:uninstall": "launchctl unload ~/Library/LaunchAgents/com.investment-project.scheduler.plist && rm ~/Library/LaunchAgents/com.investment-project.scheduler.plist",
    "price-update": "node src/jobs/priceUpdateScheduler.js --now",
    "price-update:status": "node src/jobs/priceUpdateScheduler.js --status",
    "price-update:scheduler": "node src/jobs/priceUpdateScheduler.js",
    "price-update:dry-run": "node src/jobs/priceUpdateScheduler.js --dry-run",
    "knowledge:refresh": "node src/jobs/knowledgeBaseRefresh.js",
    "knowledge:refresh-full": "node src/jobs/knowledgeBaseRefresh.js --full",
    "knowledge:status": "node src/jobs/knowledgeBaseRefresh.js --status",
    "docker:build": "docker build -t investment-project .",
    "docker:run": "docker run -p 3000:3000 --env-file .env investment-project",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:logs": "docker-compose logs -f",
    "health": "curl -s http://localhost:3000/api/health | node -e \"process.stdin.on('data', d => console.log(JSON.parse(d)))\"",
    "health:detailed": "curl -s http://localhost:3000/api/health/detailed | node -e \"process.stdin.on('data', d => console.log(JSON.stringify(JSON.parse(d), null, 2)))\""
  },
  "keywords": [
    "investment",
    "stocks",
    "analysis",
    "value-investing",
    "financial-data"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.5.0",
    "better-sqlite3-session-store": "^0.1.0",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "rss-parser": "^3.13.0",
    "uuid": "^13.0.0",
    "xml2js": "^0.6.2",
    "yahoo-finance2": "^3.10.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11"
  },
  "optionalDependencies": {
    "@sentry/node": "^7.100.0",
    "connect-redis": "^7.1.1",
    "ioredis": "^5.9.2",
    "spdy": "^4.0.2"
  }
}
