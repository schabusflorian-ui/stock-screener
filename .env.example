# ============================================
# Investment Project - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# For production, use .env.production

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# URLs
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ============================================
# Database Configuration
# ============================================
# SQLite (development - default)
DATABASE_PATH=./data/stocks.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/investment

# Connection pool settings (PostgreSQL only)
# DB_POOL_MIN=2
# DB_POOL_MAX=20
# DB_SSL=true

# ============================================
# Redis (optional, for production sessions)
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# Authentication
# ============================================
# Session secret - REQUIRED in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here_at_least_32_characters

# JWT secret (if using JWT auth)
# JWT_SECRET=your_jwt_secret_here
# JWT_EXPIRY=7d

# Google OAuth (optional)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=/api/auth/google/callback

# Admin emails (comma-separated)
# ADMIN_EMAILS=admin@example.com,another@example.com

# ============================================
# Financial Data APIs
# ============================================
# Alpha Vantage (stock data) - REQUIRED
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# FRED (Federal Reserve Economic Data) - Recommended
# Free API for macroeconomic data
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# ============================================
# Alternative Data APIs
# ============================================
# UK Companies House (FREE)
# Register at: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key

# OpenFIGI (identifier mapping)
# Register at: https://www.openfigi.com/api
OPENFIGI_API_KEY=your_openfigi_api_key

# ============================================
# AI/LLM Configuration
# ============================================
# Anthropic Claude API
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Local LLM via Ollama (optional, for cost savings)
# OLLAMA_URL=http://localhost:11434
# LLM_PREFER_LOCAL=false

# LLM usage limits (USD)
# LLM_DAILY_BUDGET=10
# LLM_MONTHLY_BUDGET=100

# ============================================
# Scheduler Configuration
# ============================================
# AUTO_START_SCHEDULER=true
# SCHEDULER_TIMEZONE=America/New_York

# ============================================
# Monitoring & Error Tracking
# ============================================
# Sentry (error tracking)
# Get DSN at: https://sentry.io/
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Log level (debug, info, warn, error)
# LOG_LEVEL=info

# ============================================
# Rate Limiting
# ============================================
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS Configuration
# ============================================
# CORS_ORIGINS=http://localhost:3001,https://yourdomain.com
