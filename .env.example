ALPHA_VANTAGE_KEY=your_alpha_vantage_key
DATABASE_PATH=./data/stocks.db

PORT=3000

# ============================================
# FRED (Federal Reserve Economic Data)
# ============================================
# Free API for macroeconomic data (yields, inflation, employment, etc.)
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# AI Analyst Configuration
# Add your Anthropic API key to enable real LLM responses
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: Local Ollama for cost savings on simple tasks
# OLLAMA_URL=http://localhost:11434

# ============================================
# Authentication (Google OAuth)
# ============================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID
# 2. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Session secret - generate a random 32+ character string
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here

# URLs for OAuth redirects
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ============================================
# XBRL Data Infrastructure (EU/UK Companies)
# ============================================
# UK Companies House API (FREE)
# Register at: https://developer.company-information.service.gov.uk/
# Rate limit: 600 requests / 5 minutes
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key

# Note: filings.xbrl.org API requires NO API key (free public access)

# ============================================
# Admin Access (Development Bypass)
# ============================================
# Set a custom admin code for the "Admin Access" button on login page
# Default is "admin" if not set. Set in frontend/.env as REACT_APP_ADMIN_CODE
# REACT_APP_ADMIN_CODE=your_custom_admin_code
